# ── MySQL connection ────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Graylinx@123
DB_NAME=jupiter_etl

# Pool — raise maxsize for heavier backfill (each concurrent device holds one conn)
DB_POOL_MIN=5
DB_POOL_MAX=30

# ── Runtime tuning ──────────────────────────────────────────────────────────
# Biggest speed lever for backfill. Too small → round-trip tax; too big →
# MySQL max_allowed_packet. 500 is safe for typical schemas; push to 1000-2000
# if your DB is tuned for larger packets.
INSERT_BATCH_SIZE=500

# Devices processed in parallel during backfill. Keep ≤ DB_POOL_MAX.
DEVICE_CONCURRENCY=8

# Always re-process last N hours on every startup (catches cron gaps from
# deploys, crashes, etc). ON DUPLICATE KEY UPDATE makes this safe.
REPROCESS_HOURS=24

# Plant backfill ignores slots within the last N intervals of now — avoids
# reading device rows that haven't been written yet.
PLANT_SAFE_INTERVALS=2

# ── Other ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# SITE_CONFIG_PATH=/etc/energy_analytics/site_config.json
