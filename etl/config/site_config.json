  "plant": {
    "normalized_table": "plant_normalized",
    "direct_params": [
      {
        "table": "cpm_0001bc0000_om_p",
        "param_id": "AMBIENT_TEMP",
        "normalized_column": "ambient_temp"
      },
      {
        "table": "cpm_0001bc0000_om_p",
        "param_id": "HUMIDITY_MONITORING",
        "normalized_column": "humidity_monitoring"
      }
    ],
    "calculated_params": [
      {
        "normalized_column": "wet_bulb_temp",
        "formula": "ambient_temp * atan(0.151977 * sqrt(humidity_monitoring + 8.313659)) + atan(ambient_temp + humidity_monitoring) - atan(humidity_monitoring - 1.676331) + 0.00391838 * pow(humidity_monitoring, 1.5) * atan(0.023101 * humidity_monitoring) - 4.686035"
      }
    ]
  },

  "btu_meter": {
    "table": "btm_0001110000_om_p",
    "params": {
      "outlet_temp": "Btu_Meter_Outlet_Temp",
      "inlet_temp": "Btu_Meter_Inlet_Temp",
      "actual_flow": "Btu_Meter_Actual_Flow",
      "actual_power": "Btu_Meter_Actual_Power",
      "energy_consump": "Btu_Meter_Energy_Consump",
      "energy_consump_mwh": "Btu_Meter_Energy_Consump_Mwh",
      "volume_m3": "Btu_Meter_Volume_m3"
    }
