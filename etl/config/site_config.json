{
  "site": {
    "site_id": "site_001",
    "site_name": "Unicharm",
    "interval_minutes": 5,
    "backfill_start_date": "2026-01-01T00:00:00",
    "lag_minutes": 10,
    "check_run_status": true
  },

  "device_types": {
    "chiller": {
      "device_table_pattern": "ch_{N}b00000_om_p",
      "run_status": { "param_id": "CH_Motor_Run", "active_value": "1.0" },
      "other_params": [
        {
          "param_id": "Act_Pwr_Total",
          "normalized_column": "kw",
          "source": "energy",
          "is_kw": true
        },
        {
          "param_id": "CH_Entering_Chilled_Lqd_Temp",
          "normalized_column": "evap_entering_temp",
          "source": "device",
          "is_kw": true
        },
        {
          "param_id": "CH_Leaving_Chilled_Lqd_Temp",
          "normalized_column": "evap_leaving_temp",
          "source": "device",
          "is_kw": true
        },
        {
          "param_id": "Flow_Meter_Eva_1",
          "normalized_column": "evap_flow",
          "source": "device",
          "is_kw": true
        }
      ],
      "direct_params": [
        {
          "table": "{device_table}",
          "param_id": "CH_Operating_hrs",
          "normalized_column": "run_hours"
        },
        {
          "table": "{device_table}",
          "param_id": "CH_Entering_CDW_Lqd_Temp",
          "normalized_column": "cond_entering_temp"
        },
        {
          "table": "{device_table}",
          "param_id": "CH_Leaving_CDW_Lqd_Temp",
          "normalized_column": "cond_leaving_temp"
        },
        {
          "table": "{device_table}",
          "param_id": "Flow_Meter_CD_1",
          "normalized_column": "cond_flow"
        },
        {
          "table": "{btu_meter_table}",
          "param_id": "Btu_Meter_Inlet_Temp",
          "normalized_column": "btu_inlet_temp"
        },
        {
          "table": "{btu_meter_table}",
          "param_id": "Btu_Meter_Outlet_Temp",
          "normalized_column": "btu_outlet_temp"
        }
      ],
      "calculated_params": [
        {
          "normalized_column": "chw_delta_t",
          "formula": "evap_entering_temp - evap_leaving_temp"
        },
        {
          "normalized_column": "tr",
          "formula": "evap_flow * (evap_entering_temp - evap_leaving_temp) * 0.33"
        },
        { "normalized_column": "kwh", "formula": "kw * on_minutes / 60" },
        { "normalized_column": "trh", "formula": "tr * on_minutes / 60" },
        {
          "normalized_column": "cumulative_kwh",
          "formula": "prev_cumulative_kwh + kwh"
        },
        {
          "normalized_column": "cumulative_trh",
          "formula": "prev_cumulative_trh + trh"
        },
        { "normalized_column": "kw_per_tr", "formula": "kw / tr" },
        {
          "normalized_column": "btu_delta_t",
          "formula": "btu_outlet_temp - btu_inlet_temp"
        },
        { "normalized_column": "chiller_load", "formula": "(tr / 550) * 100" }
      ]
    },

    "condenser_pump": {
      "device_table_pattern": "condpu_{N}b40000_om_p",
      "run_status": { "param_id": "Cnd_Pmp_Run_SS", "active_value": "active" },
      "other_params": [
        {
          "param_id": "Act_Pwr_Total",
          "normalized_column": "kw",
          "source": "energy",
          "is_kw": true
        }
      ],
      "direct_params": [],
      "calculated_params": [
        { "normalized_column": "kwh", "formula": "kw * on_minutes / 60" },
        {
          "normalized_column": "cumulative_kwh",
          "formula": "prev_cumulative_kwh + kwh"
        }
      ]
    },

    "primary_pump": {
      "device_table_pattern": "pv_{N}b20000_om_p",
      "run_status": {
        "param_id": "PriV_Pmp_Run_Fbk",
        "active_value": "active"
      },
      "other_params": [
        {
          "param_id": "PriV_Pmp_Drive_Power",
          "normalized_column": "kw",
          "source": "device",
          "is_kw": true
        }
      ],
      "direct_params": [
        {
          "table": "{device_table}",
          "param_id": "PriV_Pmp_Drive_Run_Hrs",
          "normalized_column": "run_hours"
        }
      ],
      "calculated_params": [
        { "normalized_column": "kwh", "formula": "kw * on_minutes / 60" },
        {
          "normalized_column": "cumulative_kwh",
          "formula": "prev_cumulative_kwh + kwh"
        }
      ]
    },

    "cooling_tower": {
      "device_table_pattern": "ct_{N}b70000_om_p",
      "run_status": { "param_id": "sts_on_off_00", "active_value": "active" },
      "other_params": [
        {
          "param_id": "CT_Var_Fan_1_Motor_Power",
          "normalized_column": "fan1_kw",
          "source": "device",
          "is_kw": true
        },
        {
          "param_id": "CT_Var_Fan_2_Motor_Power",
          "normalized_column": "fan2_kw",
          "source": "device",
          "is_kw": true
        },
        {
          "param_id": "CT_Var_Fan_3_Motor_Power",
          "normalized_column": "fan3_kw",
          "source": "device",
          "is_kw": true
        }
      ],
      "direct_params": [
        {
          "table": "{device_table}",
          "param_id": "CT_Var_Fan_1_Running_Hrs",
          "normalized_column": "F1_run_hours"
        },
        {
          "table": "{device_table}",
          "param_id": "CT_Var_Fan_2_Running_Hrs",
          "normalized_column": "F2_run_hours"
        },
        {
          "table": "{device_table}",
          "param_id": "CT_Var_Fan_3_Running_Hrs",
          "normalized_column": "F3_run_hours"
        }
      ],
      "calculated_params": [
        { "normalized_column": "kw", "formula": "fan1_kw + fan2_kw + fan3_kw" },
        {
          "normalized_column": "fan1_kwh",
          "formula": "fan1_kw * on_minutes / 60"
        },
        {
          "normalized_column": "fan2_kwh",
          "formula": "fan2_kw * on_minutes / 60"
        },
        {
          "normalized_column": "fan3_kwh",
          "formula": "fan3_kw * on_minutes / 60"
        },
        {
          "normalized_column": "kwh",
          "formula": "fan1_kwh + fan2_kwh + fan3_kwh"
        },
        {
          "normalized_column": "cumulative_kwh",
          "formula": "prev_cumulative_kwh + kwh"
        },
        {
          "normalized_column": "cumulative_fan1_kwh",
          "formula": "prev_cumulative_fan1_kwh + fan1_kwh"
        },
        {
          "normalized_column": "cumulative_fan2_kwh",
          "formula": "prev_cumulative_fan2_kwh + fan2_kwh"
        },
        {
          "normalized_column": "cumulative_fan3_kwh",
          "formula": "prev_cumulative_fan3_kwh + fan3_kwh"
        },
        {
          "normalized_column": "run_hours",
          "formula": "F1_run_hours + F2_run_hours + F3_run_hours"
        }
      ]
    }
  },

  "devices": [
